# Server
PORT=3001
HOST=0.0.0.0

# LLM Provider
OPENAI_API_KEY=
MODEL_ID=gpt-4o
LLM_MOCK_MODE=false

# ReAct Loop
REACT_MAX_ITERATIONS=3
TOOL_RESULT_MAX_CHARS=8192
MCP_TIMEOUT_MS=30000

# RAG
RAG_MAX_CONTENT_CHARS=16000
FILE_ENCODING=utf8

# Persistence
HUASCAR_DB_PATH=./data/huascar.db
HISTORY_LIMIT_DEFAULT=20

# MCP
MCP_STDERR=ignore

# Security Policy
SECURITY_POLICY_PATH=./src/kiro/security-policy.json

# Bypass secret for emergency override of security hooks
# Set this to a strong random value; it will be redacted from logs automatically
BYPASS_SECRET=

# Config Paths (override defaults)
STEERING_CONFIG_PATH=./src/kiro/steering.json
MCPS_CONFIG_PATH=./src/kiro/mcps.json
RAG_CONFIG_PATH=./src/kiro/rag.json

# GitHub (for MCP integration)
GITHUB_TOKEN=
