# Server
PORT=3001
HOST=0.0.0.0

# CORS — comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Metrics endpoint protection (required in production)
METRICS_SECRET=

# Frontend (build-time for Next.js, set in docker-compose or .env.local)
# NEXT_PUBLIC_API_URL=http://localhost:3001

# LLM Provider
OPENAI_API_KEY=
MODEL_ID=gpt-4o
LLM_MOCK_MODE=false
MOCK_SCENARIO=happy_path
MOCK_SCENARIOS_PATH=

# ReAct Loop
REACT_MAX_ITERATIONS=3
TOOL_RESULT_MAX_CHARS=8192
MCP_TIMEOUT_MS=30000

# RAG
RAG_MAX_CONTENT_CHARS=16000
FILE_ENCODING=utf8

# Vector Embeddings (OpenAI)
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_CHUNK_SIZE=500
EMBEDDING_TOP_K=5

# Persistence
HUASCAR_DB_PATH=./data/huascar.db
HISTORY_LIMIT_DEFAULT=20
RETENTION_EXECUTION_MAX_AGE_DAYS=90
RETENTION_EXECUTION_MAX_COUNT=10000
RETENTION_RAG_CHUNKS_MAX_PER_SOURCE=500
RETENTION_CLEANUP_ON_START=false

# MCP
MCP_STDERR=ignore

# Security Policy
SECURITY_POLICY_PATH=./src/kiro/security-policy.json

# Bypass secret for emergency override of security hooks
# Set this to a strong random value; it will be redacted from logs automatically
BYPASS_SECRET=

# Authentication
# Set AUTH_REQUIRED=true in production to enforce API key auth
AUTH_REQUIRED=false
# Comma-separated list of valid API keys
HUASCAR_API_KEYS=

# Config Paths (override defaults)
STEERING_CONFIG_PATH=./src/kiro/steering.json
MCPS_CONFIG_PATH=./src/kiro/mcps.json
RAG_CONFIG_PATH=./src/kiro/rag.json

# GitHub (for MCP integration)
GITHUB_TOKEN=
