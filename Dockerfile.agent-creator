# Stage 1: Install dependencies
FROM node:20-alpine AS deps
WORKDIR /app
COPY agent-creator/package.json agent-creator/package-lock.json ./agent-creator/
WORKDIR /app/agent-creator
RUN npm ci

# Stage 2: Run
FROM node:20-alpine AS runner
WORKDIR /app
COPY --from=deps /app/agent-creator/node_modules ./agent-creator/node_modules
COPY agent-creator ./agent-creator
EXPOSE 5173
WORKDIR /app/agent-creator
HEALTHCHECK --interval=30s --timeout=5s --start-period=15s --retries=3 \
  CMD node -e "const h=require('http');h.get('http://localhost:5173',r=>process.exit(r.statusCode===200?0:1)).on('error',()=>process.exit(1))"
CMD ["npx", "vite", "--host", "--port", "5173"]
