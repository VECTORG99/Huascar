# =============================================================================
# .dockerignore — Security-hardened exclusions
# Prevents secrets, tests, docs, and dev artifacts from leaking into image layers
# =============================================================================

# Environment and secrets (CRITICAL — prevents secret exposure in image layers)
.env
.env.*
.env.local
.env.development
.env.production
*.pem
*.key
*.cert
*.p12
*.pfx
id_rsa*
secrets/
credentials/

# Dependencies (installed during docker build)
node_modules
agent-creator/node_modules
frontend/node_modules

# Git
.git
.gitignore
.gitattributes

# Test files
test/
coverage/
.nyc_output/
*.test.*
*.spec.*
__tests__/
__mocks__/

# Documentation (not needed in production image)
docs/
*.md
!README.md

# Build artifacts (rebuilt in container)
dist
.next
out

# Database (runtime data, not build-time)
data/
*.db
*.db-wal
*.db-shm

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# CI/CD
.github/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Misc
.slim/
tmp/
.kiro/
.husky/
.editorconfig
.prettierrc*
.eslintrc*
eslint.config.*
prettier.config.*
renovate.json
